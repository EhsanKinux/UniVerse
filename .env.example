# =============================================================================
# Environment variables. Copy this file to `.env.local` for local dev, or set
# them on the server (e.g. `.env.production`) BEFORE `next build` for a deploy.
# Anything prefixed with NEXT_PUBLIC_ is inlined into the client bundle at build.
# =============================================================================

# Where the BROWSER sends API calls. Keep the same-origin `/api` prefix so
# requests go through this app and are proxied to the backend (see BACKEND_ORIGIN)
# — this works for phones/other devices too and needs no CORS. Only change it if
# the API is served from a separate public domain (e.g. https://api.example.com).
#
# PRODUCTION (uni.dowloadfiles.ir): the browser calls the backend's public
# domain directly — set this BEFORE `next build` (it is inlined into the client
# bundle AND the service worker) and enable CORS for https://uni.dowloadfiles.ir
# on the NestJS backend:
#   NEXT_PUBLIC_API_BASE_URL=https://unib.dowloadfiles.ir
NEXT_PUBLIC_API_BASE_URL=/api

# The real backend origin that Next proxies `/api/*` to, server-side (NestJS
# `univers-backend`). The backend listens privately on the same host, so this is
# a loopback address that is NEVER exposed to the browser.
#
# IMPORTANT: this is read by `rewrites()` when `next build` / `next dev` runs and
# baked into the routes manifest — set it BEFORE building to override the default.
# Setting it only in the pm2 runtime env has no effect on the proxy.
# (Frontend runs on :3002, backend on :3001 — the browser only ever sees :3002.)
BACKEND_ORIGIN=http://127.0.0.1:3001

# The campus location the nearby-food map falls back to when the user denies (or
# the device lacks) geolocation. Defaults to Tehran's Enghelab Square — set your
# real campus coordinates before `next build` (inlined into the client bundle).
NEXT_PUBLIC_CAMPUS_LAT=35.7009
NEXT_PUBLIC_CAMPUS_LNG=51.3919
